{
  "name": "@llm-exe/github-action",
  "version": "0.0.0",
  "private": true,
  "description": "GitHub Action for running llm-exe executors in workflows.",
  "main": "dist/index.js",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node20 --format=cjs --outfile=dist/index.js",
    "format:check": "prettier --check .",
    "format:write": "prettier --write .",
    "release": "bash scripts/release.sh",
    "test": "jest --config jest.config.cjs",
    "typecheck": "tsc --noEmit",
    "verify": "npm run format:check && npm run typecheck && npm test"
  },
  "dependencies": {
    "llm-exe": "^2.3.7"
  },
  "devDependencies": {
    "@tsconfig/recommended": "1.0.8",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.0.0",
    "esbuild": "0.25.4",
    "jest": "29.7.0",
    "prettier": "3.5.3",
    "ts-jest": "29.3.2",
    "typescript": "5.8.3"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
